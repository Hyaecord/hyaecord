# Copy this file to .env (git-ignored, never committed) and fill in your
# own key. Optional — Hyaecord runs fine with this unset; the GIF picker
# just only works while logged into Discord in that case (see
# src/main/gifs/giphy.ts).

# Free tier from https://developers.giphy.com — currently rate-limited to
# 100 requests/hour per key. Used only as a fallback for GIF search when
# there's no logged-in Discord session to proxy through (e.g. Stoat-only).
GIPHY_API_KEY=
